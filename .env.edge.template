# ============================================
# AI Datacenter Monitoring — Edge VM Config
# Copy to .env.edge and adjust per VM
# Usage: docker compose -f docker-compose.edge.yml --env-file .env.edge up -d --build
# ============================================

# Node identity — MUST be unique per VM
NODE_ID=frr-leaf-01
NODE_IP=192.168.56.101
NODE_ROLE=leaf

# Platform: "frr" for commodity Linux with FRR
# Uses vtysh for BGP + sysfs for thermal (no SONiC CLI)
PLATFORM=frr

# Kafka broker on the cloud VM (external listener)
# Format: <CLOUD_VM_IP>:29092
KAFKA_BROKER=192.168.56.104:29092

# Kafka topics (must match cloud .env)
KAFKA_TOPIC_METRICS=datacenter.metrics
KAFKA_TOPIC_FLOWS=datacenter.flows

# Collection interval
COLLECT_INTERVAL=5s

# ============================================
# Per-VM examples:
#
# VM1 (Spine):
#   NODE_ID=frr-spine-01
#   NODE_IP=192.168.56.101
#   NODE_ROLE=spine
#
# VM2 (Leaf):
#   NODE_ID=frr-leaf-01
#   NODE_IP=192.168.56.102
#   NODE_ROLE=leaf
#
# VM3 (Leaf):
#   NODE_ID=frr-leaf-02
#   NODE_IP=192.168.56.103
#   NODE_ROLE=leaf
# ============================================
